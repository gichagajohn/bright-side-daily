# ============================================================
# Bright Side Daily — Environment Variables
# ============================================================
# NEVER commit this file to GitHub. It is listed in .gitignore.
# Add these as GitHub Actions Secrets in your repo settings.
# ============================================================

# ── Facebook Page API ─────────────────────────────────────────
# How to get these:
#   1. Go to https://developers.facebook.com/
#   2. Create an App → Business type
#   3. Add "Pages" product
#   4. Generate a Page Access Token (never expiring via System User)
#   5. Grant pages_manage_posts, pages_read_engagement permissions

FB_PAGE_ID=123456789012345
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Dry Run Mode ────────────────────────────────────
# Set to "true" to skip actual Facebook posting (for testing)
DRY_RUN=false

# ── Optional: OpenAI (for AI-generated content replenishment) ─
# Only needed if you want GPT to generate fresh quotes
# when the library runs low. Leave empty to cycle existing library.
OPENAI_API_KEY=

# ── Timezone ─────────────────────────────────────────────────
# For display purposes only (cron runs in UTC)
TZ=Africa/Nairobi
